#!/bin/bash
# =====================================================
# Script: ตรวจสอบและแก้ไข DISABLE_WP_CRON ทุกเว็บ
# v4: เพิ่ม progress bar + spinner
# Usage:
#   bash edit-disable-wordpress                  ← scan ทุก cPanel user
#   bash edit-disable-wordpress host1            ← scan เฉพาะ user
#   bash edit-disable-wordpress host1 host2 ...  ← หลาย user
# =====================================================

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
CYAN='\033[0;36m'
BLUE='\033[0;34m'
PURPLE='\033[0;35m'
NC='\033[0m'

# ==================== Spinner ====================
SPINNER_PID=""
spinner_start() {
    local msg="$1"
    local spin='⠋⠙⠹⠸⠼⠴⠦⠧⠇⠏'
    local i=0
    while true; do
        local s=${spin:$((i % ${#spin})):1}
        printf "\r  ${CYAN}${s}${NC} %s" "$msg"
        ((i++))
        sleep 0.1
    done &
    SPINNER_PID=$!
}
spinner_stop() {
    if [[ -n "$SPINNER_PID" ]]; then
        kill "$SPINNER_PID" 2>/dev/null
        wait "$SPINNER_PID" 2>/dev/null
        SPINNER_PID=""
        printf "\r\033[K"
    fi
}

# ==================== ฟังก์ชันหา home จาก username ====================
get_home_dir() {
    local user="$1"
    if [[ "$user" == /* && -d "$user" ]]; then
        echo "$user"; return
    fi
    local home
    home=$(getent passwd "$user" 2>/dev/null | cut -d: -f6)
    if [[ -n "$home" && -d "$home" ]]; then
        echo "$home"; return
    fi
    for base in /home /home2 /home3 /home4 /home5 /home6 /home7 /home8 /home9; do
        [[ -d "$base/$user" ]] && echo "$base/$user" && return
    done
    echo ""
}

# ==================== รวบรวม SEARCH_PATHS ====================
SEARCH_PATHS=()
if [[ $# -gt 0 ]]; then
    for arg in "$@"; do
        home=$(get_home_dir "$arg")
        if [[ -n "$home" ]]; then
            SEARCH_PATHS+=("$home")
        else
            echo -e "${RED}⚠️  หาไม่พบ home directory ของ: $arg${NC}"
        fi
    done
else
    while IFS=: read -r _ _ _ _ _ homedir _; do
        [[ "$homedir" != /home* ]] && continue
        [[ ! -d "$homedir" ]] && continue
        find "$homedir" -maxdepth 3 -name "wp-config.php" -quit 2>/dev/null | grep -q . || continue
        SEARCH_PATHS+=("$homedir")
    done < /etc/passwd
fi

echo ""
echo "======================================================"
echo "   DISABLE_WP_CRON - Auto Scanner & Fixer v4"
echo "   ✅ รองรับทุก path + progress แสดงความคืบหน้า"
echo "======================================================"
echo ""
echo -e "${BLUE}📂 Home directories ที่จะสแกน:${NC}"
for path in "${SEARCH_PATHS[@]}"; do
    echo -e "   ✔ ${CYAN}$path${NC}"
done
echo ""

if [[ ${#SEARCH_PATHS[@]} -eq 0 ]]; then
    echo -e "${RED}❌ ไม่พบ home directory ที่จะสแกน${NC}"
    exit 1
fi

NOT_DISABLED=()
DISABLED=()
DUPLICATE=()

# ==================== สแกนทุก Path ====================
for SEARCH_PATH in "${SEARCH_PATHS[@]}"; do
    echo -e "${PURPLE}🔍 กำลังสแกน: $SEARCH_PATH${NC}"

    # นับจำนวน wp-config.php ทั้งหมดก่อน (เพื่อทำ progress)
    spinner_start "กำลังนับไฟล์ wp-config.php ..."
    mapfile -t ALL_CONFIGS < <(find "$SEARCH_PATH" -maxdepth 6 -name "wp-config.php" \
        -not -path "*/backup*"      \
        -not -path "*-backup*"      \
        -not -name "*.bak*"         \
        -not -name "*.bak_wpcron*"  \
        -not -path "*/cache/*"      \
        -not -path "*/uploads/*"    \
        2>/dev/null | sort)
    spinner_stop

    TOTAL_FILES=${#ALL_CONFIGS[@]}
    echo -e "  📁 พบ ${CYAN}${TOTAL_FILES}${NC} ไฟล์ wp-config.php"
    echo ""

    SCAN_COUNT=0
    for config_file in "${ALL_CONFIGS[@]}"; do
        ((SCAN_COUNT++))

        # แสดง progress ทุกไฟล์
        domain_progress=$(basename "$(dirname "$config_file")")
        printf "\r  ${CYAN}[%d/%d]${NC} สแกน: %-40s" "$SCAN_COUNT" "$TOTAL_FILES" "$domain_progress"

        # ข้าม backup
        [[ "$config_file" == *backup*      ]] && continue
        [[ "$config_file" == *-backup*     ]] && continue
        [[ "$config_file" == *.bak*        ]] && continue
        [[ "$config_file" == *.bak_wpcron* ]] && continue
        [[ "$config_file" == */cache/*     ]] && continue
        [[ "$config_file" == */uploads/*   ]] && continue

        domain=$(basename "$(dirname "$config_file")")
        if [[ "$domain" == "public_html" ]]; then
            domain=$(basename "$(dirname "$(dirname "$config_file")")")
            domain="${domain}(public_html)"
        fi

        count=$(grep -c "DISABLE_WP_CRON" "$config_file" 2>/dev/null || echo 0)

        if [[ "$count" -gt 1 ]]; then
            DUPLICATE+=("$domain|$config_file")
        elif [[ "$count" -eq 1 ]]; then
            if grep -q "define.*DISABLE_WP_CRON.*true" "$config_file" 2>/dev/null; then
                DISABLED+=("$domain|$config_file")
            else
                NOT_DISABLED+=("$domain|$config_file|set_but_false")
            fi
        else
            NOT_DISABLED+=("$domain|$config_file|not_set")
        fi
    done

    printf "\r\033[K"  # ลบบรรทัด progress
    echo -e "  ${GREEN}✅ สแกนเสร็จแล้ว ${SCAN_COUNT}/${TOTAL_FILES} ไฟล์${NC}"
    echo ""
done

# ==================== แสดงผลก่อนแก้ไข ====================

echo -e "${RED}❌ เว็บที่ยังไม่ได้ปิด (${#NOT_DISABLED[@]} เว็บ):${NC}"
echo "------------------------------------------------------"
[[ ${#NOT_DISABLED[@]} -eq 0 ]] && echo "  (ไม่มี)"
i=1
for entry in "${NOT_DISABLED[@]}"; do
    domain=$(echo "$entry" | cut -d'|' -f1)
    config=$(echo "$entry" | cut -d'|' -f2)
    status=$(echo "$entry" | cut -d'|' -f3)
    [[ "$status" == "set_but_false" ]] \
        && label="${YELLOW}[มีค่าแต่เป็น false]${NC}" \
        || label="${RED}[ไม่มีค่านี้เลย]${NC}"
    echo -e "  $i. ${CYAN}$domain${NC} $label"
    echo -e "      ${PURPLE}$config${NC}"
    ((i++))
done

echo ""
echo -e "${YELLOW}🔁 เว็บที่มีบรรทัดซ้ำ (${#DUPLICATE[@]} เว็บ):${NC}"
echo "------------------------------------------------------"
[[ ${#DUPLICATE[@]} -eq 0 ]] && echo "  (ไม่มี)"
k=1
for entry in "${DUPLICATE[@]}"; do
    domain=$(echo "$entry" | cut -d'|' -f1)
    config=$(echo "$entry" | cut -d'|' -f2)
    echo -e "  $k. ${YELLOW}$domain${NC}"
    echo -e "      ${PURPLE}$config${NC}"
    ((k++))
done

echo ""
echo -e "${GREEN}✅ เว็บที่ปิดแล้ว (${#DISABLED[@]} เว็บ):${NC}"
echo "------------------------------------------------------"
[[ ${#DISABLED[@]} -eq 0 ]] && echo "  (ไม่มี)"
j=1
for entry in "${DISABLED[@]}"; do
    domain=$(echo "$entry" | cut -d'|' -f1)
    config=$(echo "$entry" | cut -d'|' -f2)
    echo -e "  $j. ${GREEN}$domain${NC}"
    echo -e "      ${PURPLE}$config${NC}"
    ((j++))
done

TOTAL=$(( ${#NOT_DISABLED[@]} + ${#DISABLED[@]} + ${#DUPLICATE[@]} ))
echo ""
echo "======================================================"
echo -e "  📊 สรุปก่อนแก้ไข:"
for path in "${SEARCH_PATHS[@]}"; do
    count=$(find "$path" -maxdepth 6 -name "wp-config.php" \
        -not -path "*/backup*" -not -name "*.bak*" -not -name "*.bak_wpcron*" \
        2>/dev/null | wc -l)
    echo -e "  📂 $path : ${CYAN}$count เว็บ${NC}"
done
echo -e "  🔴 ยังไม่ปิด       : ${RED}${#NOT_DISABLED[@]} เว็บ${NC}"
echo -e "  🟡 ซ้ำ (ต้องลบซ้ำ) : ${YELLOW}${#DUPLICATE[@]} เว็บ${NC}"
echo -e "  🟢 ปิดแล้ว (ปกติ)  : ${GREEN}${#DISABLED[@]} เว็บ${NC}"
echo -e "  📁 ทั้งหมด         : ${CYAN}${TOTAL} เว็บ${NC}"
echo "======================================================"
echo ""

if [[ ${#NOT_DISABLED[@]} -eq 0 && ${#DUPLICATE[@]} -eq 0 ]]; then
    echo -e "${GREEN}🎉 ทุกเว็บปิด DISABLE_WP_CRON แล้ว และไม่มีบรรทัดซ้ำ!${NC}"
    exit 0
fi

# ==================== แก้ไขอัตโนมัติ ====================
echo -e "${BLUE}🔧 กำลังแก้ไข wp-config.php อัตโนมัติ...${NC}"
echo "======================================================"
echo ""

SUCCESS=()
FAILED=()

FIX_ALL=( "${NOT_DISABLED[@]}" "${DUPLICATE[@]}" )
FIX_TOTAL=${#FIX_ALL[@]}
FIX_COUNT=0

for entry in "${NOT_DISABLED[@]}"; do
    domain=$(echo "$entry" | cut -d'|' -f1)
    config=$(echo "$entry" | cut -d'|' -f2)
    status=$(echo "$entry" | cut -d'|' -f3)
    ((FIX_COUNT++))

    echo -ne "  ${CYAN}[${FIX_COUNT}/${FIX_TOTAL}]${NC} 🔧 ${CYAN}$domain${NC} ... "
    cp "$config" "${config}.bak_wpcron_$(date +%Y%m%d%H%M%S)" 2>/dev/null

    if [[ "$status" == "not_set" ]]; then
        sed -i "/^<?php/a define('DISABLE_WP_CRON', true);" "$config" 2>/dev/null
    else
        sed -i "s/define( *'DISABLE_WP_CRON' *, *false *);/define('DISABLE_WP_CRON', true);/g"  "$config" 2>/dev/null
        sed -i "s/define( *\"DISABLE_WP_CRON\" *, *false *);/define('DISABLE_WP_CRON', true);/g" "$config" 2>/dev/null
    fi

    if grep -q "define.*DISABLE_WP_CRON.*true" "$config" 2>/dev/null; then
        echo -e "${GREEN}✅ สำเร็จ${NC}"
        SUCCESS+=("$domain")
    else
        echo -e "${RED}❌ ล้มเหลว${NC}"
        FAILED+=("$domain|$config")
        backup_file=$(ls -t "${config}.bak_wpcron_"* 2>/dev/null | head -1)
        [[ -f "$backup_file" ]] && cp "$backup_file" "$config"
    fi
done

for entry in "${DUPLICATE[@]}"; do
    domain=$(echo "$entry" | cut -d'|' -f1)
    config=$(echo "$entry" | cut -d'|' -f2)
    ((FIX_COUNT++))

    echo -ne "  ${CYAN}[${FIX_COUNT}/${FIX_TOTAL}]${NC} 🔁 ${YELLOW}$domain${NC} (ลบซ้ำ) ... "
    cp "$config" "${config}.bak_wpcron_$(date +%Y%m%d%H%M%S)" 2>/dev/null

    sed -i "/DISABLE_WP_CRON/d" "$config" 2>/dev/null
    sed -i "/^<?php/a define('DISABLE_WP_CRON', true);" "$config" 2>/dev/null

    if grep -q "define.*DISABLE_WP_CRON.*true" "$config" 2>/dev/null; then
        echo -e "${GREEN}✅ สำเร็จ${NC}"
        SUCCESS+=("$domain")
    else
        echo -e "${RED}❌ ล้มเหลว${NC}"
        FAILED+=("$domain|$config")
        backup_file=$(ls -t "${config}.bak_wpcron_"* 2>/dev/null | head -1)
        [[ -f "$backup_file" ]] && cp "$backup_file" "$config"
    fi
done

# ==================== สรุปหลังแก้ไข ====================
echo ""
echo "======================================================"
echo -e "  📊 สรุปหลังแก้ไข:"
echo -e "  ✅ แก้ไขสำเร็จ : ${GREEN}${#SUCCESS[@]} เว็บ${NC}"
echo -e "  ❌ แก้ไขล้มเหลว: ${RED}${#FAILED[@]} เว็บ${NC}"
echo -e "  🟢 ปิดอยู่แล้ว : ${GREEN}${#DISABLED[@]} เว็บ${NC}"
echo -e "  📁 ทั้งหมด     : ${CYAN}${TOTAL} เว็บ${NC}"
echo "======================================================"

if [[ ${#FAILED[@]} -gt 0 ]]; then
    echo ""
    echo -e "${RED}⚠️  เว็บที่แก้ไขล้มเหลว (ตรวจสอบ permission):${NC}"
    for entry in "${FAILED[@]}"; do
        domain=$(echo "$entry" | cut -d'|' -f1)
        config=$(echo "$entry" | cut -d'|' -f2)
        echo -e "  - ${RED}$domain${NC}"
        echo -e "    → $config"
    done
fi

echo ""
echo -e "${YELLOW}💡 Backup: wp-config.php.bak_wpcron_YYYYMMDDHHMMSS${NC}"
echo ""
